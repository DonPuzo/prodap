# Copy this file to .env and fill in real local values. Never commit .env.

DEBUG=True
SECRET_KEY=change-this-to-a-random-secret-in-any-real-deployment
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL connection for the local `prodap` database created per the
# CREATE DATABASE / CREATE USER instructions in README.md
DB_NAME=prodap
DB_USER=prodap_user
DB_PASSWORD=changeme
DB_HOST=localhost
DB_PORT=5432

# Which university tenant this instance serves (single-tenant for MVP,
# see PRODAP_AGENT_BUILD_PROMPT_V2.md section 4 point 4)
TENANT_NAME=Demo Federal University
